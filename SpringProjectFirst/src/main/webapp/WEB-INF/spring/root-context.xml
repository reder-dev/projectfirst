<!-- 디비연결정보 객체 (hikariCP) -->	
<!-- Data Source - DB의    연결정보 객체 (hikariCP)-->		
<bean id="dataSource"
		class="com.zaxxer.hikari.HikariDataSource"
		destroy-method="close">
		
		<constructor-arg ref="hikariConfig"/>
</bean>

<!-- Data Source - DB의    연결정보 객체 (hikariCP)-->		

<!-- SqlSessionFactory - 디비연결(Connection), SQL 실행, 
                         MyBatis 설정, mapper 실행 -->
<bean id="sqlSessionFactory"
		class="org.mybatis.spring.SqlSessionFactoryBean">
		<property name="dataSource" ref="dataSource" />
		<property name="configLocation" 
					value="classpath:/mybatis-config.xml"/>
		<property name="mapperLocations"
					value="classpath:/mappers/**/*Mapper.xml "></property>
		
</bean>



<!-- SqlSessionFactory - 디비연결(Connection), SQL 실행 ,
							MyBatis 설정, mapper 설정 -->


<!-- SqlSessionTemle 객체 - 자동 디비 연결(Connection)/종료,
							트래젝션 관리, 쓰레드 처리 안정성 높임,
							SQL 실행, MyBatis설정, mapper설정 -->

<bean id="sqlSession" 
		class="org.mybatis.spring.SqlSessionTemplate"
		destroy-method="close">
		<constructor-arg name="sqlSessionFactory" ref="sqlSessionFactory" />


</bean>





<!-- SqlSessionTemle 객체 - 자동 디비 연결(Connection)/종료,
							트래젝션 관리, 쓰레드 처리 안정성 높임,
							SQL 실행, MyBatis설정, mapper설정 -->


	
	<!-- 외부에서 생성된 객체(빈)을 찾아와서 사용가능 설정 -->
	<context:component-scan base-package="com.hr.persistence" />	
	<context:component-scan base-package="com.hr.service" />	
		
</beans>
